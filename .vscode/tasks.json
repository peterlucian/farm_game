{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build GDExtension",
      "type": "shell",
      "command": "C:/msys64/ucrt64/bin/scons",
      "args": ["platform=windows"],
      "options": {
        "cwd": "${workspaceFolder}/cpp"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}